# Copy this file to .env and fill in your values
# cp .env.example .env

# Database
DB_PASSWORD=change_me_strong_password

# Meilisearch
MEILISEARCH_MASTER_KEY=change_me_meilisearch_key_32chars

# MinIO / Object Storage
MINIO_ACCESS_KEY=huggingbay
MINIO_SECRET_KEY=change_me_minio_secret

# JWT signing secret (generate with: openssl rand -hex 32)
JWT_SECRET=change_me_jwt_secret_64chars_minimum_please_generate_a_real_one

# Public URL of your site (used in magnet links and CORS)
PUBLIC_URL=https://your-domain.com

# Tracker announce URL (leave empty to use only public trackers)
# Set to: udp://your-domain.com:6969/announce
TRACKER_ANNOUNCE_URL=

# Exposed ports (change if something else is already using these on your host)
HTTP_PORT=80
HTTPS_PORT=443
TRACKER_PORT=6969
MINIO_CONSOLE_PORT=9001
